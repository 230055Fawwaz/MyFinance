{
    "env": {
        "browser": true,
        "es2021": true
    },
    "globals": {
        "Chart": "readonly"
    },
    "extends": ["eslint:recommended", "prettier"],
    "parserOptions": {
        "ecmaVersion": 12,
        "sourceType": "script"
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-console": "off",
        "semi": ["error", "always"]
    }
}
